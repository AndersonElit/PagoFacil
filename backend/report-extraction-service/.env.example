# --- AWS / S3 (floci en dev, AWS real en staging/prod) ---
AWS_ENDPOINT_URL=${FLOCI_ENDPOINT:-http://localhost:4566}
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
REPORT_BUCKET=reports
# --- Kafka (VPS nativo) ---
KAFKA_BOOTSTRAP_SERVERS=${VPS_IP:-localhost}:29092
# --- Read model CQRS (PostgreSQL nativo en VPS) ---
JDBC_URL=jdbc:postgresql://${VPS_IP:-localhost}:5432/pagofacil_readmodel
JDBC_TABLE=ventas
JDBC_USER=app
JDBC_PASSWORD=app
