C4Container
    title PagoFacil — Diagrama de Contenedores (C4 Nivel 2)

    Person(usuario, "Usuario Final", "Opera la billetera digital.")
    Person(auditor, "Auditor / Compliance", "Dashboard de auditoría y reportería regulatoria.")
    Person(admin, "Administrador", "Configuración de límites y reglas.")

    System_Ext(cognito, "AWS Cognito", "Identity Provider")
    System_Ext(entFinanciera, "Entidades Financieras / Pasarelas")
    System_Ext(kycProvider, "Proveedor KYC")
    System_Ext(amlSanctions, "Listas AML (OFAC/ONU)")

    Container_Boundary(b_pf, "PagoFacil Platform") {

        Container(web, "pagofacil-web", "Next.js 15.3 / React 19 / TypeScript 5", "SPA/SSR: billetera, historial, dashboard de auditoría. Vercel.")
        Container(apigw, "AWS API Gateway v2", "HTTP API", "Punto único de entrada. Valida JWT de Cognito. Enruta al cluster por ruta.")

        Container_Boundary(b_domain, "Servicios de Dominio — K3d (dev) / EKS (staging+prod)") {
            Container(identity, "identity-service", "Spring Boot 3.4.1 / WebFlux / Java 21", "BC-01: Registro, KYC, autenticación MFA, sesiones.")
            Container(wallet, "wallet-service", "Spring Boot 3.4.1 / WebFlux / Java 21", "BC-02: Saldo, depósito, retiro, transferencia (ACID + Outbox).")
            Container(fraud, "fraud-service", "Spring Boot 3.4.1 / WebFlux / Java 21", "BC-03: Motor de fraude en tiempo real y verificación AML.")
            Container(notification, "notification-service", "Spring Boot 3.4.1 / WebFlux / Java 21", "BC-04: Notificaciones transaccionales y de seguridad.")
            Container(audit, "audit-service", "Spring Boot 3.4.1 / WebFlux / Java 21", "BC-05: Dashboard de revisión, gestión de alertas, exportación de reportes.")
            Container(projection, "projection-service", "Spring Boot 3.4.1 / WebFlux / R2DBC / Java 21", "Proyector CQRS: consume eventos Kafka y escribe Read Model en pagofacil_readmodel (PostgreSQL). Único escritor.")
        }

        Container(integration, "integration-service", "Apache Camel 4.10.2 / Narayana LRA / Java 21", "BC-06: ACL hacia sistemas externos. Orquestador de sagas (Deposito, Retiro, Transferencia). Rutas Camel con Resilience4j y circuit breaker.")
        Container(lra, "Narayana LRA Coordinator", "Narayana 6.x — Docker floci-net (dev) / EKS (staging+prod)", "Coordina el ciclo de vida de las sagas LRA.")

        Container_Boundary(b_reporting, "Subsistema de Reportería (BC-07)") {
            Container(ms1, "report-extraction-service MS1", "Spark 3.5.1 / Scala 2.13 / K8s CronJob", "Extrae datos del Read Model vía JDBC (SparkJdbcSourceAdapter); genera Parquet raw/ en S3.")
            Container(ms2, "report-processing-service MS2", "Spark 3.5.1 / Scala 2.13 / K8s CronJob", "Transforma Parquet por ReportType (Factory); genera Parquet processed/ en S3.")
            Container(lambdaKafka, "Lambda Kafka Consumer", "AWS Lambda / Python 3.12", "Consume report.processed; publica a EventBridge.")
            Container(eventbridge, "EventBridge pagofacil-report-bus", "AWS EventBridge", "Enruta por format a la lambda correspondiente.")
            Container(lPdf, "lambda-pdf", "AWS Lambda / Python 3.12", "Genera PDF desde Parquet processed/.")
            Container(lXls, "lambda-xls", "AWS Lambda / Python 3.12", "Genera XLS desde Parquet processed/.")
            Container(lCsv, "lambda-csv", "AWS Lambda / Python 3.12", "Genera CSV desde Parquet processed/.")
        }

        Container(kafka, "Apache Kafka 3.7.0 (KRaft)", "Event Bus", "Bus de eventos de dominio. Topics por bounded context. mTLS + ACL.")

        ContainerDb(dbIdentity, "pagofacil_identity_service", "PostgreSQL 16.3", "Usuarios, KYC, credenciales, sesiones MFA.")
        ContainerDb(dbWallet, "pagofacil_wallet_service", "PostgreSQL 16.3", "Billeteras, transacciones, fuentes de fondos, outbox.")
        ContainerDb(dbFraud, "pagofacil_fraud_service", "PostgreSQL 16.3", "Reglas de fraude, alertas, resultados AML, outbox.")
        ContainerDb(dbNotification, "pagofacil_notification_service", "PostgreSQL 16.3", "Notificaciones enviadas, plantillas.")
        ContainerDb(dbIntegration, "pagofacil_integration_service", "PostgreSQL 16.3", "saga_instance, saga_step_log, outbox (estado de coordinación LRA).")
        ContainerDb(dbReadModel, "pagofacil_readmodel", "PostgreSQL 16.3", "Read Model CQRS: report_transactions, report_alerts, report_wallets, report_reconciliations. Propiedad de projection-service.")
        ContainerDb(dbReporting, "pagofacil_reporting", "PostgreSQL 16.3", "report_schema_catalog. Propiedad de reporting context.")
        ContainerDb(s3, "S3 — Parquet + Reports", "AWS S3", "raw/ y processed/ (contrato ETL entre MS1 y MS2); pagofacil-reports/ (PDF/XLS/CSV finales).")
    }

    Rel(usuario, web, "Opera billetera", "HTTPS")
    Rel(auditor, web, "Dashboard de auditoría", "HTTPS")
    Rel(admin, web, "Configuración operacional", "HTTPS")
    Rel(web, apigw, "Solicitudes API + JWT", "HTTPS / REST")
    Rel(apigw, cognito, "Valida token JWT", "HTTPS")
    Rel(apigw, identity, "Enruta /v1/identity/*", "HTTP / mTLS")
    Rel(apigw, wallet, "Enruta /v1/wallet/*", "HTTP / mTLS")
    Rel(apigw, fraud, "Enruta /v1/fraud/*", "HTTP / mTLS")
    Rel(apigw, audit, "Enruta /v1/audit/*", "HTTP / mTLS")

    Rel(identity, dbIdentity, "ACID R/W", "R2DBC")
    Rel(wallet, dbWallet, "ACID R/W + Outbox", "R2DBC")
    Rel(fraud, dbFraud, "R/W + Outbox", "R2DBC")
    Rel(notification, dbNotification, "Escritura de entregas", "R2DBC")
    Rel(integration, dbIntegration, "Estado saga + Outbox", "R2DBC")
    Rel(projection, dbReadModel, "Escribe Read Model (único escritor)", "R2DBC")
    Rel(audit, dbReadModel, "Lee Read Model", "R2DBC")
    Rel(ms1, dbReadModel, "Lee tablas desnormalizadas para ETL", "JDBC / SparkJdbcSourceAdapter")
    Rel(ms1, dbReporting, "Consulta report_schema_catalog", "JDBC / SparkJdbcSourceAdapter")

    Rel(identity, kafka, "Publica eventos BC-01", "Kafka producer / mTLS")
    Rel(wallet, kafka, "Publica eventos BC-02 vía Outbox relay", "Kafka producer / mTLS")
    Rel(fraud, kafka, "Publica eventos BC-03 vía Outbox relay", "Kafka producer / mTLS")
    Rel(integration, kafka, "Publica/consume eventos de saga", "Kafka producer+consumer / mTLS")
    Rel(projection, kafka, "Consume todos los eventos de dominio", "Kafka consumer / mTLS")
    Rel(ms1, kafka, "Publica report.extracted", "Kafka producer / mTLS")
    Rel(ms2, kafka, "Consume report.extracted; publica report.processed", "Kafka consumer+producer / mTLS")
    Rel(lambdaKafka, kafka, "Consume report.processed", "Kafka consumer / mTLS")

    Rel(ms1, s3, "Escribe Parquet raw/", "S3 API")
    Rel(ms2, s3, "Lee raw/; escribe processed/", "S3 API")
    Rel(lambdaKafka, eventbridge, "Publica a pagofacil-report-bus", "EventBridge API")
    Rel(eventbridge, lPdf, "Enruta format=PDF", "EventBridge Rule")
    Rel(eventbridge, lXls, "Enruta format=XLS", "EventBridge Rule")
    Rel(eventbridge, lCsv, "Enruta format=CSV", "EventBridge Rule")
    Rel(lPdf, s3, "Escribe PDF en pagofacil-reports/", "S3 API")
    Rel(lXls, s3, "Escribe XLS en pagofacil-reports/", "S3 API")
    Rel(lCsv, s3, "Escribe CSV en pagofacil-reports/", "S3 API")

    Rel(wallet, integration, "Solicita saga Deposito/Retiro/Transferencia", "HTTP / mTLS")
    Rel(integration, wallet, "Compensaciones saga (REST idempotente)", "HTTP / mTLS")
    Rel(integration, fraud, "Solicita evaluación fraude en saga Retiro", "HTTP / mTLS")
    Rel(integration, identity, "Transmite resultado KYC", "HTTP / mTLS")
    Rel(integration, notification, "Publica notificaciones de resultado de integración", "Kafka / mTLS")
    Rel(integration, lra, "Registra y coordina sagas LRA", "HTTP / REST")

    Rel(integration, entFinanciera, "Instrucciones de pago y solicitudes de fondeo", "HTTPS / REST")
    Rel(entFinanciera, integration, "Webhooks de confirmación de fondeo/retiro", "HTTPS")
    Rel(integration, kycProvider, "Solicita validación KYC", "HTTPS / REST")
    Rel(integration, amlSanctions, "Consulta listas de sanciones AML", "HTTPS / REST")
