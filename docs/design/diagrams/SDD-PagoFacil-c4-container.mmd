C4Container
    title PagoFacil — Diagrama de Contenedores (C4 Nivel 2)

    Person_Ext(usuarioFinal, "Usuario Final", "Opera con su billetera digital desde el navegador")
    Person_Ext(operadorInterno, "Operador Interno", "Administrador, Analista de Fraude, Oficial de Cumplimiento")

    System_Ext(proveedorKYC, "Proveedor KYC", "Validación biométrica de identidad")
    System_Ext(proveedorAML, "Proveedor AML", "Listas de sanciones")
    System_Ext(entidadesFinancieras, "Entidades Financieras", "Depósitos y retiros bancarios")
    System_Ext(pasarelas, "Pasarelas de Pago", "Notificaciones de pago firmadas")
    System_Ext(proveedorSMSEmail, "Proveedor SMS/Email", "Notificaciones transaccionales")

    Container_Boundary(pagofacil, "PagoFacil") {
        Container(frontend, "Frontend", "Next.js 14 / TypeScript", "Interfaz web para usuarios finales y operadores internos")
        Container(apiGateway, "API Gateway", "AWS API Gateway v2", "Punto de entrada único. JWT authorizer Cognito, rate limiting y routing a microservicios.")
        Container(cognito, "AWS Cognito", "OAuth 2.0 / OpenID Connect", "Identity Provider. Emisión y validación de JWT con claims rol y tenant_id.")

        Container(identityService, "identity-service", "Spring Boot 3 WebFlux / Java 21", "BC-01: Registro, onboarding KYC, autenticación MFA, ciclo de vida de usuario")
        Container(walletService, "wallet-service", "Spring Boot 3 WebFlux / Java 21", "BC-02: Billeteras digitales, saldos, límites transaccionales, cuentas bancarias vinculadas")
        Container(fraudService, "fraud-compliance-service", "Spring Boot 3 WebFlux / Java 21", "BC-03: Evaluación de riesgo, detección de fraude, alertas AML y compliance")
        Container(notificationService, "notification-service", "Spring Boot 3 WebFlux / Java 21", "BC-04: Envío de notificaciones (email/SMS/push) por canal configurado")
        Container(integrationService, "integration-service", "Apache Camel 4 / Spring Boot / Java 21", "BC-05: ACL para sistemas externos, orquestador de sagas (Narayana LRA), conciliación periódica")
        Container(auditService, "audit-service", "Spring Boot 3 WebFlux / Java 21", "BC-06: Registro inmutable de trazas de auditoría. Append-only.")
        Container(projectionService, "projection-service", "Spring Boot 3 WebFlux / Java 21", "BC-07: Proyector CQRS. Consume eventos Kafka y escribe tablas desnormalizadas en el read model. Único escritor de pagofacil_readmodel.")
        Container(ms1, "report-extraction-service (MS1)", "Apache Spark 3.5 / Scala 3 — K8s CronJob", "BC-07: Extrae datos del read model vía JDBC, valida esquema y genera Parquet raw/")
        Container(ms2, "report-processing-service (MS2)", "Apache Spark 3.5 / Scala 3 — K8s CronJob", "BC-07: Consume Parquet raw/, transforma por ReportType (Factory) y genera Parquet processed/")
        Container(lambdaConsumer, "Lambda Kafka Consumer", "AWS Lambda Python 3.12", "Consume topic report.processed y publica evento a EventBridge")
        Container(eventBridge, "AWS EventBridge", "Event Bus", "Enruta report.processed a la lambda de formato correspondiente (PDF/XLS/CSV)")
        Container(lambdaFormatos, "Lambdas de Formato", "AWS Lambda Python 3.12", "Genera PDF, XLS o CSV desde Parquet processed/ y escribe en S3 output/")
        Container(lraCoordinator, "Narayana LRA Coordinator", "Narayana LRA (systemd VPS / K8s pod)", "Coordina el ciclo de vida de sagas distribuidas con compensación automática. Puerto 50000.")

        ContainerDb(kafkaBus, "Apache Kafka", "Kafka 3 KRaft (MSK en staging/prod)", "Bus de eventos de dominio y pipeline ETL. Topics por bounded context.")
        ContainerDb(identityDb, "pagofacil_identity_service", "PostgreSQL 16", "Usuarios, KYC, MFA, sesiones, outbox, idempotencia")
        ContainerDb(walletDb, "pagofacil_wallet_service", "PostgreSQL 16", "Wallets, transacciones, límites transaccionales, cuentas bancarias, outbox")
        ContainerDb(fraudDb, "pagofacil_fraud_compliance_service", "PostgreSQL 16", "Alertas de fraude/AML, reglas de detección, evaluaciones de riesgo, outbox")
        ContainerDb(notificationDb, "pagofacil_notification_service", "PostgreSQL 16", "Notificaciones enviadas, plantillas, preferencias de canal")
        ContainerDb(integrationDb, "pagofacil_integration_service", "PostgreSQL 16", "Instancias de saga, log de pasos, eventos externos, registros de conciliación, outbox")
        ContainerDb(auditDb, "pagofacil_audit_service", "MongoDB 7 (append-only)", "Trazas inmutables de auditoría con actor, acción, IP y correlationId")
        ContainerDb(readModelDb, "pagofacil_readmodel", "PostgreSQL 16", "Read model CQRS: tablas desnormalizadas optimizadas para extracción ETL")
        ContainerDb(reportingDb, "pagofacil_reporting", "PostgreSQL 16", "Catálogo report_schema_catalog y metadatos de ejecuciones de reportes")
        ContainerDb(s3Store, "S3 / Almacenamiento Parquet", "Amazon S3 (floci en dev)", "Parquet raw/, processed/ y output/ PDF/XLS/CSV del pipeline ETL")
        ContainerDb(secretsManager, "AWS Secrets Manager", "Vault de secretos", "Claves de cifrado, credenciales de integración y tokens de servicio. Rotación automática.")
    }

    Rel(usuarioFinal, frontend, "Opera con su billetera", "HTTPS")
    Rel(operadorInterno, frontend, "Dashboard de auditoría y compliance", "HTTPS")
    Rel(frontend, apiGateway, "Invoca APIs REST versionadas", "HTTPS / JWT")
    Rel(apiGateway, cognito, "Valida JWT en cada solicitud", "HTTPS")
    Rel(apiGateway, identityService, "Rutas /auth y /users", "HTTPS / JWT")
    Rel(apiGateway, walletService, "Rutas /wallets", "HTTPS / JWT")
    Rel(apiGateway, fraudService, "Rutas /compliance/alerts", "HTTPS / JWT")
    Rel(apiGateway, auditService, "Rutas /audit/traces", "HTTPS / JWT")
    Rel(apiGateway, integrationService, "Webhooks entrantes de sistemas externos", "HTTPS / OAuth 2.0")

    Rel(identityService, kafkaBus, "Publica: UserRegistered, KYCApproved, KYCRejected, AccountSuspendedByAML", "Kafka / JSON")
    Rel(walletService, kafkaBus, "Publica: WalletCreated, DepositCompleted, TransferCompleted, WithdrawalCompleted", "Kafka / JSON")
    Rel(fraudService, kafkaBus, "Publica: FraudAlertCreated, ComplianceAlertResolved", "Kafka / JSON")
    Rel(notificationService, kafkaBus, "Consume eventos para generar notificaciones", "Kafka / JSON")
    Rel(auditService, kafkaBus, "Consume todos los eventos de dominio (audit trail inmutable)", "Kafka / JSON")
    Rel(projectionService, kafkaBus, "Consume eventos de todos los bounded contexts", "Kafka / JSON")
    Rel(integrationService, kafkaBus, "Publica/consume eventos de saga y orquestación", "Kafka / JSON")
    Rel(ms1, kafkaBus, "Publica: report.extracted, report.extraction_failed", "Kafka / JSON")
    Rel(ms2, kafkaBus, "Consume: report.extracted; Publica: report.processed, report.processing_failed", "Kafka / JSON")
    Rel(lambdaConsumer, kafkaBus, "Consume: report.processed", "Kafka / JSON")

    Rel(identityService, identityDb, "Lee/escribe", "R2DBC / PostgreSQL")
    Rel(walletService, walletDb, "Lee/escribe", "R2DBC / PostgreSQL")
    Rel(fraudService, fraudDb, "Lee/escribe", "R2DBC / PostgreSQL")
    Rel(notificationService, notificationDb, "Lee/escribe", "R2DBC / PostgreSQL")
    Rel(integrationService, integrationDb, "Lee/escribe sagas y outbox", "R2DBC / PostgreSQL")
    Rel(auditService, auditDb, "Escribe trazas append-only", "Reactive MongoDB Driver")
    Rel(projectionService, readModelDb, "Escribe proyecciones CQRS (único escritor)", "R2DBC / PostgreSQL")
    Rel(ms1, readModelDb, "Lee datos del read model (solo lectura)", "Spark JDBC")
    Rel(ms1, reportingDb, "Consulta catálogo de esquemas", "Spark JDBC")
    Rel(ms1, s3Store, "Escribe Parquet en raw/", "S3 API")
    Rel(ms2, s3Store, "Lee raw/, escribe processed/", "S3 API")
    Rel(lambdaConsumer, eventBridge, "Publica evento de formato", "EventBridge PutEvents")
    Rel(eventBridge, lambdaFormatos, "Enruta por formato (PDF/XLS/CSV)", "Lambda Invoke")
    Rel(lambdaFormatos, s3Store, "Escribe PDF/XLS/CSV en output/", "S3 API")

    Rel(integrationService, lraCoordinator, "Gestiona ciclo de vida de sagas (iniciar, compensar, confirmar)", "REST HTTP — puerto 50000")
    Rel(integrationService, proveedorKYC, "Solicita validación KYC", "HTTPS / OAuth 2.0")
    Rel(proveedorKYC, integrationService, "Notifica resultado KYC", "Webhook HTTPS firmado")
    Rel(integrationService, proveedorAML, "Consulta listas de sanciones", "HTTPS / API Key")
    Rel(integrationService, entidadesFinancieras, "Solicita procesamiento de retiros", "HTTPS / OAuth 2.0")
    Rel(entidadesFinancieras, integrationService, "Notifica confirmaciones de depósito y retiro", "HTTPS / OAuth 2.0")
    Rel(pasarelas, integrationService, "Notifica pagos firmados digitalmente", "Webhook HTTPS")
    Rel(integrationService, proveedorSMSEmail, "Delega envío de notificaciones externas", "HTTPS / API Key")

    Rel(integrationService, secretsManager, "Lee credenciales de sistemas externos", "AWS SDK")
    Rel(identityService, secretsManager, "Lee secretos de cifrado y configuración", "AWS SDK")
